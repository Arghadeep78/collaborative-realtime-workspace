# ─── Server ───────────────────────────────────────────────
PORT=3030

# ─── MongoDB ──────────────────────────────────────────────
# Either set DB_CLUSTER_URL to a full connection string:
#   DB_CLUSTER_URL=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/workspace
# ...or provide the split parts (username/password are combined into an SRV URI):
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password
DB_CLUSTER_URL=cluster0.xxxxx.mongodb.net

# ─── Redis ────────────────────────────────────────────────
# Yjs pub/sub fan-out, board-metadata cache, rate-limit counters, BullMQ queues
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret
JWT_REFRESH_SECRET=your-separate-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=your-google-oauth-client-id

# ─── AI (Google Gemini) ───────────────────────────────────
GOOGLE_API_KEY=your-gemini-api-key

# ─── Email (Nodemailer / Gmail) ───────────────────────────
# Used for board-invite and password-reset emails. With Gmail, EMAIL_PASS must
# be an App Password (not your account password); requires 2FA enabled.
EMAIL_USER=your-gmail-address@gmail.com
EMAIL_PASS=your-gmail-app-password

# ─── Media uploads (Cloudinary) ───────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── CORS ─────────────────────────────────────────────────
# Allowed frontend origin(s). Use FRONTEND_URLS for a comma-separated list.
FRONTEND_URL=http://localhost:5173
# FRONTEND_URLS=https://app.example.com,https://staging.example.com
